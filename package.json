{
  "name": "waterhouse-ops-map",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 127.0.0.1",
    "dev:redesign": "vite --config vite.redesign.config.ts --host 127.0.0.1",
    "dev:server": "nodemon server/index.js",
    "build": "tsc -b && vite build",
    "build:redesign": "tsc -b && vite build --config vite.redesign.config.ts",
    "preview": "vite preview --host 127.0.0.1",
    "preview:redesign": "vite preview --config vite.redesign.config.ts --host 127.0.0.1",
    "start": "node server/index.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.1",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "tailwind-merge": "^2.6.0",
    "vite": "^7.1.12",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "nodemon": "^3.1.10",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.3"
  }
}
